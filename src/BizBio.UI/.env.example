# Environment Configuration Template
# Copy this file to .env.production on your server and update the values

# API Configuration
NUXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Node Environment
NODE_ENV=production

# Application Port
PORT=3000

# Application Insights Configuration
# Get your connection string from Azure Portal > Application Insights > Properties
NUXT_PUBLIC_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=cf8e0ef0-0844-4cfe-b49c-0838a880835b;IngestionEndpoint=https://southafricanorth-1.in.applicationinsights.azure.com/;LiveEndpoint=https://southafricanorth.livediagnostics.monitor.azure.com/;ApplicationId=12ed36f7-1a54-438d-b149-fac495a0c94d

# Google Analytics Configuration
# Get your GA4 Measurement ID from Google Analytics Admin > Data Streams
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Cookie Domain (optional, for cross-subdomain tracking)
# NUXT_PUBLIC_COOKIE_DOMAIN=.yourdomain.com
