/* theme-tweaker.js - Refactored with TT_SECTIONS as single source of truth
 *
 * Features:
 * - TT_SECTIONS defines all variables in one place
 * - Auto-hides fields if CSS variable not present in template
 * - Uses Alpine.js for reactive UI
 * - Supports color, gradient, select, and font fields
 *
 * Usage:
 *   <link rel="stylesheet" href="./css/theme-tweaker.css">
 *   <script defer src="./js/theme-tweaker.js"></script>
 */

(() => {
  const BASE_STORAGE_KEY = "themeTweaker:v4";

  // ==========================================================================
  // TT_SECTIONS: Single source of truth for all theme variables
  // To add a new variable, just add it here - everything else derives from this
  // ==========================================================================
  const TT_SECTIONS = [
    {
      id: "general",
      label: "General",
      fields: [
        {
          key: "mode",
          label: "Mode",
          type: "select",
          cssVar: null,
          defaultValue: "light",
          options: [
            { value: "light", label: "Light" },
            { value: "dark", label: "Dark" }
          ]
        },
        {
          key: "font",
          label: "Font",
          type: "font-select",
          cssVar: "--font-family",
          defaultValue: "Inter"
        }
      ]
    },
    {
      id: "brand",
      label: "Brand Colors",
      layout: "2col",
      fields: [
        { key: "primary", label: "Primary", type: "color", cssVar: "--primary-color", defaultValue: "#1e40af" },
        { key: "secondary", label: "Secondary", type: "color", cssVar: "--secondary-color", defaultValue: "#3b82f6" }
      ]
    },
    {
      id: "background",
      label: "Background",
      fields: [
        { key: "bg", label: "Page Background", type: "color-or-gradient", kind: "solid", cssVar: "--page-background-color", defaultValue: "#f5f5f5" },
        { key: "cardBg", label: "Card Background", type: "color", cssVar: "--card-bg-color", defaultValue: "#ffffff", layout: "2col-start" },
        { key: "avatarBorder", label: "Avatar Border", type: "color", cssVar: "--avatar-border-color", defaultValue: "#ffffff", layout: "2col-end" }
      ]
    },
    {
      id: "text",
      label: "Text Colors",
      layout: "2col",
      fields: [
        { key: "text", label: "Text Color", type: "color", cssVar: "--text-color", defaultValue: "#1e293b" },
        { key: "headerColor", label: "Header Color", type: "color", cssVar: "--header-color", defaultValue: "#ffffff" },
        { key: "subtitleColor", label: "Subtitle Color", type: "color", cssVar: "--subtitle-color", defaultValue: "#64748b" }
      ]
    },
    {
      id: "actionButtons",
      label: "Action Buttons",
      layout: "2col",
      fields: [
        { key: "actionBtnBg", label: "Background", type: "color", cssVar: "--action-button-bg-color", defaultValue: "#1e40af" },
        { key: "actionBtnText", label: "Text", type: "color", cssVar: "--action-button-text-color", defaultValue: "#ffffff" }
      ]
    },
    {
      id: "infoItems",
      label: "Info Items",
      layout: "2col",
      fields: [
        { key: "infoIconBg", label: "Icon Background", type: "color", cssVar: "--info-item-icon-bg-color", defaultValue: "#1e40af" },
        { key: "infoIconText", label: "Icon Color", type: "color", cssVar: "--info-item-icon-text-color", defaultValue: "#ffffff" },
        { key: "infoLabelColor", label: "Label Color", type: "color", cssVar: "--info-item-label-color", defaultValue: "#64748b" },
        { key: "infoTextColor", label: "Text Color", type: "color", cssVar: "--info-item-text-color", defaultValue: "#1e293b" }
      ]
    },
    {
      id: "ctaButton",
      label: "CTA Button",
      fields: [
        { key: "ctaBg", label: "Background", type: "color-or-gradient", cssVar: "--cta-button-bg-color", defaultValue: "linear-gradient(135deg, #1e40af 0%, #3b82f6 100%)" },
        { key: "ctaText", label: "Text Color", type: "color", cssVar: "--cta-button-text-color", defaultValue: "#ffffff" }
      ]
    },
    {
      id: "tagline",
      label: "Tagline",
      layout: "2col",
      fields: [
        { key: "taglineTextColor", label: "Text Color", type: "color", cssVar: "--tagline-text-color", defaultValue: "#ffffff" }
      ]
    },
    {
      id: "shapes",
      label: "Shapes",
      fields: [
        {
          key: "buttonShape",
          label: "Button Shape",
          type: "select",
          cssVar: "--button-radius",
          defaultValue: "pill",
          options: [
            { value: "square", label: "Square", cssValue: "0px" },
            { value: "rounded-sm", label: "Rounded Small", cssValue: "5px" },
            { value: "rounded-md", label: "Rounded Medium", cssValue: "10px" },
            { value: "rounded-lg", label: "Rounded Large", cssValue: "20px" },
            { value: "pill", label: "Pill", cssValue: "14px" },
            { value: "circle", label: "Circle", cssValue: "999px" }
          ]
        }
      ]
    },
    {
      id: "social",
      label: "Social Colors",
      fields: [
        {
          key: "socialColorMode",
          label: "Social Colors",
          type: "select",
          cssVar: null,
          defaultValue: "brand",
          options: [
            { value: "brand", label: "Use brand colors" },
            { value: "unified", label: "Use one color for all" }
          ]
        },
        { key: "socialUnifiedColor", label: "Unified Color", type: "color", cssVar: "--social-unified-color", defaultValue: "#1e40af" }
      ]
    }
  ];

  // ==========================================================================
  // Configuration derived from TT_SECTIONS
  // ==========================================================================
  const CFG = {
    enabled: true,
    defaultOpen: false,
    position: "right",
    storageKey: null,

    fonts: [
      { label: "Inter", value: "Inter", google: true },
      { label: "System UI", value: "system-ui" },
      { label: "Roboto", value: "Roboto", google: true },
      { label: "Open Sans", value: "Open Sans", google: true },
      { label: "Poppins", value: "Poppins", google: true },
      { label: "Montserrat", value: "Montserrat", google: true },
      { label: "Source Sans 3", value: "Source Sans 3", google: true },
      { label: "Merriweather", value: "Merriweather", google: true },
      { label: "Nunito", value: "Nunito", google: true },
      { label: "Quicksand", value: "Quicksand", google: true },
      { label: "DM Sans", value: "DM Sans", google: true },
      { label: "Plus Jakarta Sans", value: "Plus Jakarta Sans", google: true },
      { label: "Space Grotesk", value: "Space Grotesk", google: true },
      { label: "Outfit", value: "Outfit", google: true }
    ],

    socialBrandHex: {
      whatsapp: "#25D366",
      linkedin: "#0A66C2",
      instagram: "#E4405F",
      facebook: "#1877F2",
      x: "#000000",
      twitter: "#1DA1F2",
      youtube: "#FF0000",
      tiktok: "#000000",
      github: "#181717",
      stackoverflow: "#F58025",
      website: "#2563EB",
      email: "#6B7280",
      phone: "#10B981",
      map: "#EA4335",
      link: "#6B7280"
    }
  };

  // Build vars and defaults from TT_SECTIONS
  function buildVarsAndDefaults() {
    const vars = {};
    const defaults = {};

    for (const section of TT_SECTIONS) {
      for (const field of section.fields) {
        if (field.cssVar) {
          vars[field.key] = field.cssVar;
        }
        defaults[field.key] = field.defaultValue;
      }
    }

    // Add derived hover variables
    vars.primaryHover = "--primary-color-hover";
    vars.secondaryHover = "--secondary-color-hover";
    vars.actionBtnHover = "--action-button-bg-color-hover";
    vars.infoIconHover = "--info-item-icon-bg-color-hover";
    vars.ctaHover = "--cta-button-bg-color-hover";
    vars.socialUseBrand = "--social-use-brand-colors";

    return { vars, defaults };
  }

  const { vars: VARS, defaults: DEFAULTS } = buildVarsAndDefaults();

  // Merge user config
  const userCfg = window.ThemeTweakerConfig || {};
  Object.assign(CFG, userCfg);

  if (!CFG.enabled) return;

  // ==========================================================================
  // Utility functions
  // ==========================================================================
  const $ = (sel, root = document) => root.querySelector(sel);

  function safeParse(json, fallback) {
    try { return JSON.parse(json); } catch { return fallback; }
  }

  function getStoredState() {
    const raw = localStorage.getItem(CFG.storageKey);
    return safeParse(raw, null);
  }

  function storeState(state) {
    localStorage.setItem(CFG.storageKey, JSON.stringify(state));
  }

  function cloneDeep(obj) {
    return JSON.parse(JSON.stringify(obj));
  }

  function getPageKey() {
    const { pathname } = window.location;
    let file = pathname.split("/").filter(Boolean).join("/");
    if (!file || file.endsWith("/")) file += "index";
    return file.replace(/\.html?$/i, "") || "root";
  }

  // ==========================================================================
  // Color utilities
  // ==========================================================================
  function isHexColor(v) {
    return typeof v === "string" && /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(v.trim());
  }

  function expandHex(hex) {
    const h = hex.replace("#", "").trim();
    if (h.length === 3) return "#" + h.split("").map(c => c + c).join("");
    return "#" + h;
  }

  function hexToRgb(hex) {
    const h = expandHex(hex).replace("#", "");
    return {
      r: parseInt(h.slice(0, 2), 16),
      g: parseInt(h.slice(2, 4), 16),
      b: parseInt(h.slice(4, 6), 16)
    };
  }

  function rgbToHex({ r, g, b }) {
    const clamp = n => Math.max(0, Math.min(255, Math.round(n)));
    const to2 = n => n.toString(16).padStart(2, "0");
    return "#" + to2(clamp(r)) + to2(clamp(g)) + to2(clamp(b));
  }

  function rgbStringToHex(rgb) {
    const m = rgb.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/i);
    if (!m) return null;
    return rgbToHex({ r: Number(m[1]), g: Number(m[2]), b: Number(m[3]) });
  }

  function darkenHex(hex, amount = 0.12) {
    if (!isHexColor(hex)) return hex;
    const { r, g, b } = hexToRgb(hex);
    return rgbToHex({ r: r * (1 - amount), g: g * (1 - amount), b: b * (1 - amount) });
  }

  function darkenGradientString(gradient, amount = 0.10) {
    if (typeof gradient !== "string") return gradient;
    const matches = gradient.match(/#([0-9a-f]{3}|[0-9a-f]{6})/gi);
    if (!matches) return gradient;
    let out = gradient;
    for (const m of matches) {
      out = out.replace(new RegExp(m.replace("#", "\\#"), "g"), darkenHex(m, amount));
    }
    return out;
  }

  function computeHoverColor(value) {
    const v = String(value || "").trim();
    if (isHexColor(v)) return darkenHex(v, 0.12);
    if (v.toLowerCase().includes("gradient(")) return darkenGradientString(v, 0.10);
    return v;
  }

  function normalizeColorLike(value) {
    const v = (value || "").trim();
    if (!v) return "";
    if (v.startsWith("#")) return v;
    if (v.startsWith("rgb(") || v.startsWith("rgba(")) return rgbStringToHex(v) || v;
    return v;
  }

  function parseLinearGradient(gradientStr) {
    const s = (gradientStr || "").trim();
    if (!s.toLowerCase().startsWith("linear-gradient")) return null;
    const angleMatch = s.match(/linear-gradient\(\s*([-\d.]+)\s*deg/i);
    const angle = angleMatch ? Number(angleMatch[1]) : 180;
    const hexes = s.match(/#([0-9a-f]{3}|[0-9a-f]{6})/ig) || [];
    return { angle, start: hexes[0] || null, end: hexes[1] || hexes[0] || null };
  }

  function makeLinearGradient(angleDeg, startHex, endHex) {
    const a = Number.isFinite(angleDeg) ? angleDeg : 0;
    const start = isHexColor(startHex) ? startHex : "#000000";
    const end = isHexColor(endHex) ? endHex : "#ffffff";
    return `linear-gradient(${Math.round(a)}deg, ${start} 0%, ${end} 100%)`;
  }

  function getButtonRadius(shape) {
    const map = {
      "square": "0px",
      "rounded-sm": "5px",
      "rounded-md": "10px",
      "rounded-lg": "20px",
      "pill": "14px",
      "circle": "999px"
    };
    return map[shape] || "14px";
  }

  function getButtonShapeFromRadius(radius) {
    const r = (radius || "").trim();
    if (r === "0px" || r === "0") return "square";
    if (r === "5px") return "rounded-sm";
    if (r === "10px") return "rounded-md";
    if (r === "20px") return "rounded-lg";
    if (r === "999px") return "circle";
    return "pill";
  }

  // ==========================================================================
  // Detect available CSS variables in the template
  // ==========================================================================
  function detectAvailableVars() {
    const available = {};
    const style = getComputedStyle(document.documentElement);

    for (const section of TT_SECTIONS) {
      for (const field of section.fields) {
        if (field.cssVar) {
          const value = style.getPropertyValue(field.cssVar).trim();
          available[field.key] = value !== "";
        } else {
          // Non-CSS fields (like mode, socialColorMode) are always available
          available[field.key] = true;
        }
      }
    }

    return available;
  }

  function readCssVar(name, fallback = "") {
    const v = getComputedStyle(document.documentElement).getPropertyValue(name);
    return (v || "").trim() || fallback;
  }

  // ==========================================================================
  // Derive defaults from host CSS
  // ==========================================================================
  function deriveDefaultsFromHostCss() {
    const state = cloneDeep(DEFAULTS);

    for (const section of TT_SECTIONS) {
      console.log(`Deriving values for section: ${section.id}`);
      for (const field of section.fields) {
        console.log(`  Checking field: ${field.key} (CSS var: ${field.cssVar})`);
        if (!field.cssVar) continue;

        const raw = readCssVar(field.cssVar);
        if (!raw) continue;

        if (field.type === "color") {
          state[field.key] = normalizeColorLike(raw);
          console.log(`    Detected color value: ${state[field.key]}`);
        } else if (field.type === "color-or-gradient") {
          state[field.key] = raw;
          // Parse gradient components
          const parsed = parseLinearGradient(raw);
          console.log(`    Detected ${parsed ? "gradient" : "solid"} value: ${raw}`);
          if (parsed) {
            state[`_${field.key}Kind`] = "gradient";
            state[`_${field.key}Angle`] = parsed.angle;
            state[`_${field.key}Start`] = parsed.start;
            state[`_${field.key}End`] = parsed.end;
          } else {
            state[`_${field.key}Kind`] = "solid";
            state[`_${field.key}Solid`] = normalizeColorLike(raw);
          }
          console.log(`    State:`, state);
        } else if (field.type === "select" && field.key === "buttonShape") {
          state.buttonShape = getButtonShapeFromRadius(raw);
        } else if (field.type === "font-select") {
          state[field.key] = raw.split(",")[0].replace(/['"]/g, "").trim() || field.defaultValue;
        } else {
          state[field.key] = raw;
        }
      }
    }

    // Initialize gradient UI state if not set
    if (!state._bgKind) {
      console.log("Initializing background gradient state");
      state._bgKind = "solid";
      state._bgSolid = state.bg || DEFAULTS.bg;
      state._bgAngle = 135;
      state._bgStart = state.primary || DEFAULTS.primary;
      state._bgEnd = state.secondary || DEFAULTS.secondary;
    }

    if (!state._ctaBgKind) {
      const parsed = parseLinearGradient(state.ctaBg);
      console.log(`Initializing CTA background gradient state: ${parsed ? "gradient" : "solid"}`);
      state._ctaBgKind = parsed ? "gradient" : "solid";
      state._ctaBgAngle = parsed?.angle ?? 135;
      state._ctaBgStart = parsed?.start ?? state.primary;
      state._ctaBgEnd = parsed?.end ?? state.secondary;
      state._ctaBgSolid = normalizeColorLike(state.ctaBg) || state.primary;
    }

    return state;
  }

  // ==========================================================================
  // Apply state to DOM
  // ==========================================================================
  function applyState(state) {
    const root = document.documentElement;

    root.setAttribute("data-theme", state.mode);
    root.classList.toggle("tt-dark", state.mode === "dark");
    root.setAttribute("data-tt-social", state.socialColorMode === "unified" ? "unified" : "brand");

    // Materialize gradients
    if (state._bgKind === "gradient") {
      state.bg = makeLinearGradient(state._bgAngle, state._bgStart, state._bgEnd);
    } else if (state._bgSolid) {
      state.bg = state._bgSolid;
    }

    if (state._ctaBgKind === "gradient") {
      state.ctaBg = makeLinearGradient(state._ctaBgAngle, state._ctaBgStart, state._ctaBgEnd);
    } else if (state._ctaBgSolid) {
      state.ctaBg = state._ctaBgSolid;
    }

    // Apply all CSS variables from TT_SECTIONS
    for (const section of TT_SECTIONS) {
      for (const field of section.fields) {
        if (!field.cssVar) continue;

        let value = state[field.key];

        // Handle button shape -> radius conversion
        if (field.key === "buttonShape") {
          value = getButtonRadius(state.buttonShape);
        }

        if (value !== undefined && value !== null) {
          root.style.setProperty(field.cssVar, value);
        }
      }
    }

    // Apply hover colors
    root.style.setProperty(VARS.primaryHover, computeHoverColor(state.primary));
    root.style.setProperty(VARS.secondaryHover, computeHoverColor(state.secondary));
    root.style.setProperty(VARS.actionBtnHover, computeHoverColor(state.actionBtnBg));
    root.style.setProperty(VARS.infoIconHover, computeHoverColor(state.infoIconBg));
    root.style.setProperty(VARS.ctaHover, computeHoverColor(state.ctaBg));

    // Social
    root.style.setProperty(VARS.socialUseBrand, state.socialColorMode === "brand" ? "1" : "0");

    // Font
    const fontMeta = CFG.fonts.find(f => f.value === state.font);
    if (fontMeta?.google) ensureGoogleFontLoaded(fontMeta.value);

    const fontVar = state.font === "system-ui"
      ? "system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif"
      : `'${state.font}', system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif`;
    root.style.setProperty("--font-family", fontVar);
  }

  function ensureGoogleFontLoaded(fontName) {
    const id = `tt-font-${fontName.replace(/\s+/g, "-").toLowerCase()}`;
    if (document.getElementById(id)) return;

    if (!document.getElementById("tt-preconnect-gfonts")) {
      const pre1 = document.createElement("link");
      pre1.id = "tt-preconnect-gfonts";
      pre1.rel = "preconnect";
      pre1.href = "https://fonts.googleapis.com";
      document.head.appendChild(pre1);

      const pre2 = document.createElement("link");
      pre2.rel = "preconnect";
      pre2.href = "https://fonts.gstatic.com";
      pre2.crossOrigin = "anonymous";
      document.head.appendChild(pre2);
    }

    const link = document.createElement("link");
    link.id = id;
    link.rel = "stylesheet";
    link.href = `https://fonts.googleapis.com/css2?family=${encodeURIComponent(fontName).replace(/%20/g, "+")}:wght@300;400;500;600;700&display=swap`;
    document.head.appendChild(link);
  }

  // ==========================================================================
  // Alpine.js Component
  // ==========================================================================
  function createAlpineComponent(initialState, availableVars) {
    return {
      open: CFG.defaultOpen,
      state: initialState,
      available: availableVars,
      sections: TT_SECTIONS,
      fonts: CFG.fonts,

      // Gradient UI state
      dialInstances: {},

      init() {
        this.$watch("state", () => this.persistAndApply(), { deep: true });
      },

      toggle() {
        this.open = !this.open;
        document.body.classList.toggle("tt-show", this.open);
      },

      close() {
        this.open = false;
        document.body.classList.remove("tt-show");
      },

      persistAndApply() {
        storeState(this.state);
        applyState(this.state);
      },

      reset() {
        const fresh = deriveDefaultsFromHostCss();
        console.log("Resetting to defaults derived from host CSS:", fresh);
        Object.assign(this.state, fresh);
        this.persistAndApply();
      },

      isFieldAvailable(field) {
        return this.available[field.key] !== false;
      },

      isSectionVisible(section) {
        return section.fields.some(f => this.isFieldAvailable(f));
      },

      getGradientPreview(key) {
        const angle = this.state[`_${key}Angle`] || 135;
        const start = this.state[`_${key}Start`] || "#000000";
        const end = this.state[`_${key}End`] || "#ffffff";
        return makeLinearGradient(angle, start, end);
      },

      updateGradientAngle(key, angle) {
        this.state[`_${key}Angle`] = angle;
      }
    };
  }

  // ==========================================================================
  // Create UI with Alpine
  // ==========================================================================
  function createUI(state, availableVars) {
    // Create the wrapper element
    const wrap = document.createElement("div");
    wrap.className = "tt-wrap";
    wrap.setAttribute("x-data", "themeTweaker");
    wrap.innerHTML = `
      <!-- FAB Button -->
      <div class="tt-fab" @click="toggle" tabindex="0" @keydown.enter="toggle">
        <span class="tt-chip">Theme</span>
        <span style="font-size:12px;opacity:.85">Customize</span>
      </div>

      <!-- Panel -->
      <div class="tt-panel" :class="{ 'tt-open': open }" @keydown.escape.window="close">
        <!-- Header -->
        <div class="tt-head">
          <div>
            <div class="tt-title">Theme Tweaker</div>
            <div class="tt-hint">Customize CSS variables. Changes are saved per page.</div>
          </div>
          <div class="tt-actions">
            <button class="tt-btn" @click="reset">Reset</button>
            <button class="tt-btn" @click="close">Close</button>
          </div>
        </div>

        <!-- Body -->
        <div class="tt-body">
          <template x-for="section in sections" :key="section.id">
            <template x-if="isSectionVisible(section)">
              <div>
                <!-- Section Title -->
                <div class="tt-section-title" x-text="section.label"></div>

                <!-- Section Fields -->
                <div :class="{ 'tt-grid2': section.layout === '2col' }">
                  <template x-for="field in section.fields" :key="field.key">
                    <template x-if="isFieldAvailable(field)">
                      <div class="tt-row">
                        <!-- Color Field -->
                        <template x-if="field.type === 'color'">
                          <label x-text="field.label"></label>
                        </template>
                        <template x-if="field.type === 'color'">
                          <input type="color" x-model="state[field.key]" />
                        </template>

                        <!-- Select Field -->
                        <template x-if="field.type === 'select'">
                          <label x-text="field.label"></label>
                        </template>
                        <template x-if="field.type === 'select'">
                          <select x-model="state[field.key]">
                            <template x-for="opt in field.options" :key="opt.value">
                              <option :value="opt.value" x-text="opt.label"></option>
                            </template>
                          </select>
                        </template>

                        <!-- Font Select Field -->
                        <template x-if="field.type === 'font-select'">
                          <label x-text="field.label"></label>
                        </template>
                        <template x-if="field.type === 'font-select'">
                          <select x-model="state[field.key]">
                            <template x-for="f in fonts" :key="f.value">
                              <option :value="f.value" x-text="f.label"></option>
                            </template>
                          </select>
                        </template>

                        <!-- Color or Gradient Field -->
                        <template x-if="field.type === 'color-or-gradient'">
                          <div style="grid-column: 1 / -1;">
                            <div class="tt-row" style="margin-bottom: 8px;">
                              <label x-text="field.label"></label>
                              <select x-model="state['_' + field.key + 'Kind']">
                                <option value="solid">Solid</option>
                                <option value="gradient">Gradient</option>
                              </select>
                            </div>

                            <!-- Solid -->
                            <div x-show="state['_' + field.key + 'Kind'] === 'solid'" class="tt-row">
                              <label>Color</label>
                              <input type="color" x-model="state['_' + field.key + 'Solid']" />
                            </div>

                            <!-- Gradient -->
                            <div x-show="state['_' + field.key + 'Kind'] === 'gradient'" class="tt-gradient-row">
                              <div class="tt-gradient-box">
                                <div class="tt-row" style="grid-template-columns:1fr auto">
                                  <label>Start</label>
                                  <input type="color" x-model="state['_' + field.key + 'Start']" />
                                </div>
                                <div class="tt-row" style="grid-template-columns:1fr auto">
                                  <label>End</label>
                                  <input type="color" x-model="state['_' + field.key + 'End']" />
                                </div>
                                <div class="tt-gradient-preview" :style="'background:' + getGradientPreview(field.key)"></div>
                              </div>
                              <div class="tt-gradient-box">
                                <div class="tt-dial-wrap">
                                  <label class="tt-dial-label">Angle</label>
                                  <input type="range" min="0" max="360"
                                         x-model.number="state['_' + field.key + 'Angle']"
                                         style="width: 80px;" />
                                  <span x-text="state['_' + field.key + 'Angle'] + '°'" style="font-size: 11px;"></span>
                                </div>
                              </div>
                            </div>
                          </div>
                        </template>
                      </div>
                    </template>
                  </template>
                </div>

                <div class="tt-sep"></div>
              </div>
            </template>
          </template>
        </div>

        <!-- Footer -->
        <div class="tt-foot">
          <span class="tt-mono">var(--primary-color)</span> etc. in your CSS
        </div>
      </div>
    `;

    document.body.appendChild(wrap);

    // Register Alpine component
    document.addEventListener("alpine:init", () => {
      Alpine.data("themeTweaker", () => createAlpineComponent(state, availableVars));
    });

    // If Alpine already loaded, initialize manually
    if (window.Alpine) {
      Alpine.data("themeTweaker", () => createAlpineComponent(state, availableVars));
      Alpine.initTree(wrap);
    }
  }

  // ==========================================================================
  // Inject base social color styles
  // ==========================================================================
  function injectBaseSocialStyles() {
    if (document.getElementById("tt-social-styles")) return;

    const socialVars = Object.entries(CFG.socialBrandHex)
      .map(([k, v]) => `--social-${k}: ${v};`)
      .join("\n  ");

    const style = document.createElement("style");
    style.id = "tt-social-styles";
    style.textContent = `
:root {
  ${socialVars}
}

.tt-social { color: var(--social-unified-color, #1e40af); }

:root[data-tt-social="brand"] .tt-social[data-kind="whatsapp"]{color:var(--social-whatsapp)}
:root[data-tt-social="brand"] .tt-social[data-kind="linkedin"]{color:var(--social-linkedin)}
:root[data-tt-social="brand"] .tt-social[data-kind="instagram"]{color:var(--social-instagram)}
:root[data-tt-social="brand"] .tt-social[data-kind="facebook"]{color:var(--social-facebook)}
:root[data-tt-social="brand"] .tt-social[data-kind="x"]{color:var(--social-x)}
:root[data-tt-social="brand"] .tt-social[data-kind="twitter"]{color:var(--social-twitter)}
:root[data-tt-social="brand"] .tt-social[data-kind="youtube"]{color:var(--social-youtube)}
:root[data-tt-social="brand"] .tt-social[data-kind="tiktok"]{color:var(--social-tiktok)}
:root[data-tt-social="brand"] .tt-social[data-kind="github"]{color:var(--social-github)}
:root[data-tt-social="brand"] .tt-social[data-kind="stackoverflow"]{color:var(--social-stackoverflow)}
:root[data-tt-social="brand"] .tt-social[data-kind="website"]{color:var(--social-website)}
:root[data-tt-social="brand"] .tt-social[data-kind="email"]{color:var(--social-email)}
:root[data-tt-social="brand"] .tt-social[data-kind="phone"]{color:var(--social-phone)}
:root[data-tt-social="brand"] .tt-social[data-kind="map"]{color:var(--social-map)}
:root[data-tt-social="brand"] .tt-social[data-kind="link"]{color:var(--social-link)}

:root[data-tt-social="unified"] .tt-social{color:var(--social-unified-color)}
`;
    document.head.appendChild(style);
  }

  // ==========================================================================
  // Initialize
  // ==========================================================================
  function init() {
    CFG.storageKey = `${BASE_STORAGE_KEY}:${getPageKey()}`;

    // Detect which CSS variables are available in this template
    const availableVars = detectAvailableVars();

    // Get state from localStorage or derive from CSS
    const hostDefaults = deriveDefaultsFromHostCss();
    const stored = getStoredState();
    const state = Object.assign({}, hostDefaults, stored || {});

    // Apply state and create UI
    injectBaseSocialStyles();
    applyState(state);
    createUI(state, availableVars);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  // ==========================================================================
  // Public API
  // ==========================================================================
  window.ThemeTweaker = {
    getState: () => cloneDeep(getStoredState() || DEFAULTS),
    reset: () => { localStorage.removeItem(CFG.storageKey); location.reload(); },
    getSections: () => TT_SECTIONS,
    getAvailableVars: detectAvailableVars
  };

  window.TT_SECTIONS = TT_SECTIONS;
})();
